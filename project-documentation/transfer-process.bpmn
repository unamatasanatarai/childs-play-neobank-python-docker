  <bpmn:process id="TransferProcess" isExecutable="true">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_DB" name="Database">
        <bpmn:flowNodeRef>BeginTx</bpmn:flowNodeRef>
