      <bpmn:outgoing>Flow_01fht8g</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="BeginTx" name="BEGIN TRANSACTION">
      <bpmn:outgoing>Flow_02bg0my</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="LockSender" name="Lock Sender">
