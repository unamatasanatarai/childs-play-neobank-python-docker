        <bpmn:flowNodeRef>Event_1o86yxv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ValidInputGateway</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_User" name="User">
        <bpmn:flowNodeRef>StartEvent</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent" name="Transfer Requested" />
    <bpmn:task id="AuthTask" name="Authenticate User" />
    <bpmn:task id="ValidateInput" name="Validate Input" />
